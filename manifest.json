{
  "manifest_version": 3,
  "name": "짤 콜렉터",
  "version": "0.1.0",
  "description": "Collect matching images from the active webpage into a downloads folder.",
  "permissions": [
    "activeTab",
    "downloads",
    "downloads.ui",
    "scripting",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "짤 콜렉터"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "options_page": "options.html"
}
